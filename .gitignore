# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Caches
.ruff_cache/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Data artifacts (regenerated by scripts 01/02/09)
data/raw/*
data/processed/*
data/lmdb/*
data/figures/*
data/metadata.sqlite
data/splits.json
data/mace_features/
data/model_cache/
!data/**/.gitkeep

# Training logs / checkpoints (regenerated, huge)
logs/
training_runs.log
pipeline.pid

# Internal/ad-hoc workflow shell scripts (not part of public pipeline)
scripts/_run_*.sh

# Heavy run artifacts (regenerable, multi-MB)
results/runs/*/embeddings*.npy
results/runs/*/*.ckpt

# Keep in git:
#   results/figures/                       <- dissertation outputs (small, critical)
#   results/runs/*/config.yaml
#   results/runs/*/metrics.json
#   results/runs/*/predictions.parquet     <- small (~50KB), needed for 06_compare
#   results/runs/*/figures/                <- per-run diagnostics
#   results/runs/*/env.txt                 <- git hash + dependency snapshot
#   results/summary.json
#   results/comparison_table.md
#   results/multiseed_summary.md
#   results/dissertacao_metrics.md
